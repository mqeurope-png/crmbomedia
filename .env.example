APP_NAME="CRMBO Media CRM"
ENVIRONMENT=development
DATABASE_URL=mysql+pymysql://crm:crm@localhost:3306/crm
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-admin-password

# Fernet key (44-char urlsafe base64) used to encrypt integration API keys
# at rest. Required: the app refuses to start without it. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key invalidates all stored ciphertext — see docs/security.md.
INTEGRATION_SECRETS_KEY=replace-with-fernet-key

# Public URL of the frontend, used to build the password-reset link inside
# the email body. In development the default is fine; in production set it
# to the public domain (e.g. https://crm.tudominio.com).
FRONTEND_BASE_URL=http://localhost:3000

# SMTP / email service. Leave SMTP_HOST empty in development: the app falls
# back to ConsoleEmailService and prints the rendered email to stdout. To
# enable real delivery in production, fill all of SMTP_HOST/PORT/USER/
# PASSWORD/FROM in .env.production and set ENVIRONMENT=production.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=CRMBO Media CRM
# SMTP_USE_TLS=true   # STARTTLS on port 587
# SMTP_USE_SSL=false  # implicit SSL on port 465; mutually exclusive with TLS

# Error tracking. Leave SENTRY_DSN / NEXT_PUBLIC_SENTRY_DSN empty in dev so
# the SDK stays uninitialized and no events are sent. See docs/security.md
# "Error tracking" for the privacy contract (send_default_pii=false +
# before_send scrubbing of password/token/email).
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# GIT_SHA=                  # CI sets this from $GITHUB_SHA; release tag in Sentry
# NEXT_PUBLIC_GIT_SHA=      # mirror exposed to the browser bundle
