# Nginx vhost template for CRMBO Media CRM behind Plesk (or any external
# reverse proxy that terminates TLS). HTTP-only; no certbot mounts.
#
# Copy to deploy/nginx/conf.d/app.conf before running the stack with the
# Plesk override:
#
#   cp deploy/nginx/conf.d/app.plesk.conf.example deploy/nginx/conf.d/app.conf
#
# The Nginx container exposes this on 127.0.0.1:8080 (see
# docker-compose.plesk.yml) and Plesk proxies the public domain to it.
#
# NO static `upstream` blocks on purpose. nginx resolves upstream
# hostnames ONCE at config load and caches the IP; after a
# `docker compose up --force-recreate api frontend` the recreated
# containers get new IPs on the docker network and nginx keeps proxying
# to the dead ones (502 connect() failed) until restarted. Docker's
# embedded DNS (127.0.0.11) + a variable-based proxy_pass force a fresh
# lookup per request, so container recreation is picked up within
# `valid=10s` with no nginx restart.

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    resolver 127.0.0.11 valid=10s ipv6=off;

    # Trust the Plesk-provided X-Forwarded-Proto. The connection from Plesk
    # to this container is plain HTTP, so $scheme would always be "http"
    # even when the user is on HTTPS.
    set $forwarded_proto $http_x_forwarded_proto;
    if ($forwarded_proto = "") {
        set $forwarded_proto $scheme;
    }

    location = /healthz {
        access_log off;
        return 200 "ok\n";
        default_type text/plain;
    }

    location /api/ {
        set $upstream_api http://api:8000;
        proxy_pass $upstream_api;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $forwarded_proto;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
        # Composer asset uploads can exceed the default 1 MB.
        client_max_body_size 12m;
    }

    # Email-template inline images (Tiptap uploads) are served straight
    # off disk so the API process never has to stream binary bytes back.
    # The host mounts the directory matching the API container's
    # `EMAIL_ASSETS_DIR` env var (defaults to /opt/crmbo/uploads/email-templates).
    location ^~ /assets/email-templates/ {
        alias /opt/crmbo/uploads/email-templates/;
        autoindex off;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000, immutable";
        add_header X-Content-Type-Options nosniff always;
        try_files $uri =404;
    }

    location / {
        set $upstream_frontend http://frontend:3000;
        proxy_pass $upstream_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $forwarded_proto;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_read_timeout 60s;
    }
}
