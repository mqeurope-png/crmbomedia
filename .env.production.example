# Production environment template.
#
# Copy to .env.production and fill in REAL secrets:
#   cp .env.production.example .env.production
#   chmod 600 .env.production
#
# .env.production is gitignored. Do NOT commit it.
# Generate strong secrets, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

APP_NAME="CRMBO Media CRM"
ENVIRONMENT=production

# Public URL the browser will use to reach the API. Behind Nginx this is the
# same hostname as the frontend; Nginx routes /api/* to the api container.
NEXT_PUBLIC_API_BASE_URL=https://crm.tudominio.com

# Allowed CORS origins (comma-separated). With same-origin Nginx routing,
# this can usually match NEXT_PUBLIC_API_BASE_URL.
CORS_ORIGINS=https://crm.tudominio.com

# JWT signing key. MUST be a long, random secret. Rotate by re-issuing tokens.
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Initial admin user, created on first boot if it does not exist.
DEFAULT_ADMIN_EMAIL=admin@tudominio.com
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password

# MySQL credentials. The api container uses MYSQL_USER + MYSQL_PASSWORD.
# MYSQL_ROOT_PASSWORD is only used for backups/restore from the host.
MYSQL_DATABASE=crm
MYSQL_USER=crm
MYSQL_PASSWORD=replace-with-a-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password

# Fernet key (44-char urlsafe base64) used to encrypt integration API keys
# at rest. Required: the app refuses to start without it. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key invalidates all stored ciphertext — see docs/security.md.
INTEGRATION_SECRETS_KEY=replace-with-fernet-key

# Public URL of the frontend, embedded in the password-reset email link.
# Must match what the user can reach from the public internet.
FRONTEND_BASE_URL=https://crm.tudominio.com

# SMTP / email service for password reset.
# Defaults below assume IONOS SMTP (free for IONOS-hosted deploys, requires
# an existing mailbox). Alternatives that also work: SendGrid (smtp.sendgrid.net),
# Postmark (smtp.postmarkapp.com), Brevo (smtp-relay.brevo.com), AWS SES
# (email-smtp.<region>.amazonaws.com). See docs/security.md "Email service".
SMTP_HOST=smtp.ionos.es
SMTP_PORT=587
SMTP_USER=noreply@tudominio.com
SMTP_PASSWORD=replace-with-mailbox-password
SMTP_FROM=noreply@tudominio.com
SMTP_FROM_NAME=CRMBO Media CRM
SMTP_USE_TLS=true
SMTP_USE_SSL=false
